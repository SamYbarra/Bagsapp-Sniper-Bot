# Helius RPC URL (required)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Jito RPC URL (optional, defaults to mainnet)
JITO_RPC_URL=https://mainnet.block-engine.jito.wtf

# Yellowstone gRPC URL (optional, defaults to localhost)
YELLOWSTONE_GRPC_URL=grpc://localhost:10000

# Wallet Private Key (required) - Base58 encoded
PRIVATE_KEY=your_base58_encoded_private_key_here

# Bagsapp Program ID (optional, defaults to placeholder)
BAGSAPP_PROGRAM_ID=Bagapp111111111111111111111111111111111

# Trading Parameters
SLIPPAGE_BPS=500
MAX_BUY_AMOUNT_SOL=1.0
MIN_BUY_AMOUNT_SOL=0.1

# Stop Loss and Take Profit (in percentage)
STOP_LOSS_PERCENT=10
TAKE_PROFIT_PERCENT=50

# Monitoring
CHECK_INTERVAL_MS=1000

# Logging
LOG_LEVEL=info
